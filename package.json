{
  "name": "@kittipos/openclaw-notebook-tools",
  "version": "0.1.0",
  "description": "OpenClaw plugin: read and edit Jupyter notebooks",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "openclaw.plugin.json", "src/skills"],
  "openclaw": { "extensions": ["./dist/index.js"] },
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
