{
  "name": "@kittipos/openclaw-notebook-tools",
  "version": "0.1.0",
  "description": "OpenClaw plugin: read and edit Jupyter notebooks",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "src/skills"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist *.tgz",
    "plugin:build": "pnpm build && openclaw plugins build --entry ./dist/index.js",
    "plugin:check": "pnpm build && openclaw plugins build --entry ./dist/index.js --check",
    "plugin:validate": "openclaw plugins validate --entry ./dist/index.js",
    "pack:plugin": "pnpm plugin:build && npm pack"
  },
  "dependencies": {
    "nanoid": "^5.0.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  }
}
